# Copy this file to `.env` and fill in real values. Never commit the real `.env`.

# Postgres connection string (managed DB, e.g. Neon/Supabase/Render).
# Neon example (note ?sslmode=require):
#   postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Strong random secret used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-value"

# Port the API listens on
PORT=8080

# Public URL of the deployed frontend (used for CORS)
FRONTEND_URL=https://hostel-allocation-system.vercel.app
